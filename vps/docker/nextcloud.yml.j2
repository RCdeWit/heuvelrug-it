services:
  nextcloud-db:
    image: postgres:15-alpine
    restart: always
    volumes:
      - nextcloud_db:/var/lib/postgresql/data
    environment:
      POSTGRES_DB: nextcloud
      POSTGRES_USER: nextcloud
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    command: >
      postgres
      -c shared_buffers=2GB
      -c effective_cache_size=10GB
      -c maintenance_work_mem=512MB
      -c checkpoint_completion_target=0.9
      -c wal_buffers=16MB
      -c default_statistics_target=100
      -c random_page_cost=1.1
      -c effective_io_concurrency=200
      -c work_mem=4MB
      -c min_wal_size=1GB
      -c max_wal_size=4GB
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U nextcloud"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    restart: always
    volumes:
      - redis_data:/data
    command: redis-server --requirepass ${REDIS_PASSWORD} --maxmemory 512mb --maxmemory-policy allkeys-lru --appendonly yes
    healthcheck:
      test: ["CMD", "redis-cli", "--raw", "incr", "ping"]
      interval: 10s
      timeout: 3s
      retries: 3

  nextcloud:
    image: nextcloud:33.0.0
    restart: always
    depends_on:
      - nextcloud-db
      - redis
    volumes:
      - nextcloud_data:/var/www/html
      - {{ mount_point }}/ncdata:/var/www/html/data
      - ./nextcloud/nextcloud-entrypoint.sh:/custom-entrypoint.sh:ro
    entrypoint: ["/custom-entrypoint.sh"]
    environment:
      POSTGRES_HOST: nextcloud-db
      POSTGRES_DB: nextcloud
      POSTGRES_USER: nextcloud
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      NEXTCLOUD_ADMIN_USER: ${NEXTCLOUD_ADMIN_USER}
      NEXTCLOUD_ADMIN_PASSWORD: ${NEXTCLOUD_ADMIN_PASSWORD}
      REDIS_HOST: redis
      REDIS_HOST_PORT: 6379
      REDIS_HOST_PASSWORD: ${REDIS_PASSWORD}
      NEXTCLOUD_TRUSTED_DOMAINS: drive.{{ domain }}
      OVERWRITEPROTOCOL: https
      OVERWRITEHOST: drive.{{ domain }}
      OVERWRITECLIURL: https://drive.{{ domain }}
      # SMTP Configuration (using official Nextcloud Docker env vars)
      SMTP_HOST: ${SMTP_HOST}
      SMTP_PORT: ${SMTP_PORT}
      SMTP_SECURE: ${SMTP_SECURE}
      SMTP_AUTHTYPE: ${SMTP_AUTHTYPE}
      SMTP_NAME: ${SMTP_NAME}
      SMTP_PASSWORD: ${SMTP_PASSWORD}
      MAIL_FROM_ADDRESS: ${MAIL_FROM_ADDRESS}
      MAIL_DOMAIN: ${MAIL_DOMAIN}
      # Nextcloud Talk configuration (for entrypoint script)
      TURN_SECRET: ${TURN_SECRET}
      SIGNALING_SECRET: ${SIGNALING_SECRET}
    ports:
      - 8080:80
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:80/status.php"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 90s

  collabora:
    image: collabora/code:25.04.9.3.1
    restart: always
    environment:
      # Allowed Nextcloud instance (WOPI client)
      - aliasgroup1=https://drive.{{ domain }}:443
      # Security: Restrict WOPI requests to only come from the nextcloud container
      # This prevents unauthorized hosts from requesting document content
      - extra_params=--o:ssl.enable=false --o:ssl.termination=true --o:storage.wopi.host[0]=nextcloud
      - dictionaries=en_US nl_NL
    volumes:
      - ./collabora/fonts:/opt/collaboraoffice/share/fonts/truetype/custom:ro
    ports:
      - 9980:9980
    cap_add:
      - MKNOD
      - SYS_CHROOT
    security_opt:
      - apparmor:unconfined
      - seccomp:unconfined

  nextcloud-cron:
    image: nextcloud:33.0.0
    restart: always
    depends_on:
      - nextcloud
      - nextcloud-db
      - redis
    volumes:
      - nextcloud_data:/var/www/html
      - {{ mount_point }}/ncdata:/var/www/html/data
    environment:
      POSTGRES_HOST: nextcloud-db
      POSTGRES_DB: nextcloud
      POSTGRES_USER: nextcloud
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      REDIS_HOST: redis
      REDIS_HOST_PORT: 6379
      REDIS_HOST_PASSWORD: ${REDIS_PASSWORD}
    entrypoint: /cron.sh

  # Client Push daemon - provides real-time updates to desktop/mobile clients
  # Replaces polling with efficient push notifications via WebSocket
  notify_push:
    image: nextcloud:33.0.0
    restart: always
    # Run as www-data (uid 33) to match file ownership from nextcloud container
    user: "33:33"
    depends_on:
      - nextcloud
      - nextcloud-db
      - redis
    volumes:
      # Not read-only - binary needs execute permission
      - nextcloud_data:/var/www/html
      - {{ mount_point }}/ncdata:/var/www/html/data:ro
    environment:
      # Port for the push server to listen on
      PORT: 7867
      # Nextcloud URL (internal Docker network)
      NEXTCLOUD_URL: http://nextcloud
    ports:
      - 7867:7867
    entrypoint: ["/bin/sh", "-c"]
    command:
      - |
        echo "Waiting for Nextcloud to initialize and install notify_push app..."
        while [ ! -f /var/www/html/custom_apps/notify_push/bin/x86_64/notify_push ]; do
          sleep 10
        done
        echo "Starting notify_push daemon..."
        exec /var/www/html/custom_apps/notify_push/bin/x86_64/notify_push /var/www/html/config/config.php
    healthcheck:
      test: ["CMD", "sh", "-c", "wget -q --spider http://localhost:7867/metrics || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 120s

  backup:
    image: restic/restic:0.18.1
    restart: always
    depends_on:
      - nextcloud
      - nextcloud-db
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - {{ mount_point }}/nextcloud_db:/mnt/data/nextcloud_db:ro
      - {{ mount_point }}/nextcloud_data:/mnt/data/nextcloud_data:ro
      - {{ mount_point }}/ncdata:/mnt/data/ncdata:ro
      - {{ mount_point }}/redis_data:/mnt/data/redis_data:ro
      - ./nextcloud/backup.sh:/backup.sh:ro
      - backup_temp:/backup
    environment:
      RESTIC_PASSWORD: ${RESTIC_PASSWORD}
      RESTIC_REPOSITORY: s3:${AWS_S3_ENDPOINT}/${AWS_S3_BUCKET}
      AWS_ACCESS_KEY_ID: ${AWS_ACCESS_KEY_ID}
      AWS_SECRET_ACCESS_KEY: ${AWS_SECRET_ACCESS_KEY}
      AWS_S3_ENDPOINT: ${AWS_S3_ENDPOINT}
      AWS_S3_BUCKET: ${AWS_S3_BUCKET}
      BACKUP_RETENTION_DAYS: ${BACKUP_RETENTION_DAYS}
      HEALTHCHECK_URL: ${HEALTHCHECK_URL:-}
    entrypoint: ["/bin/sh", "-c"]
    command:
      - |
        apk add --no-cache docker-cli curl logrotate
        cat > /etc/logrotate.conf << 'EOF'
        /var/log/backup.log {
            weekly
            rotate 8
            compress
            missingok
            notifempty
            create 0640 root root
        }
        EOF
        (echo "0 2 * * * /bin/sh /backup.sh >> /var/log/backup.log 2>&1"; echo "0 3 * * 0 /usr/sbin/logrotate /etc/logrotate.conf") | crontab -
        crond -f -l 2

  # ClamAV antivirus daemon for file scanning
  clamav:
    image: clamav/clamav:1.5.1
    restart: always
    volumes:
      - clamav_data:/var/lib/clamav
    healthcheck:
      test: ["CMD", "clamdscan", "--ping", "3"]
      interval: 60s
      timeout: 10s
      retries: 3
      start_period: 120s

  # ============================================================================
  # Nextcloud Talk - Video Conferencing Components
  # ============================================================================

  # TURN server for NAT traversal - required for reliable video calls
  coturn:
    image: coturn/coturn:4.9.0
    restart: always
    network_mode: host
    volumes:
      - ./talk/turnserver.conf:/etc/coturn/turnserver.conf:ro
    healthcheck:
      test: ["CMD", "turnadmin", "-l", "-N", "127.0.0.1", "-p", "3478"]
      interval: 30s
      timeout: 10s
      retries: 3

  # High Performance Backend (HPB) - signaling server for 5+ participant calls
  signaling:
    image: strukturag/nextcloud-spreed-signaling:2.1.0
    restart: always
    depends_on:
      - nextcloud
      - nats
      - janus
    volumes:
      - ./talk/signaling.conf:/config/server.conf:ro
    ports:
      - 8081:8080
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:8080/api/v1/welcome"]
      interval: 30s
      timeout: 10s
      retries: 3

  # NATS server - message broker required by the signaling server
  nats:
    image: nats:2.12.5
    restart: always
    command: ["-c", "/etc/nats/nats.conf"]
    volumes:
      - ./talk/nats.conf:/etc/nats/nats.conf:ro

  # Janus WebRTC gateway - media server for the signaling backend
  janus:
    image: mwalbeck/janus-gateway:1.4.0
    restart: always
    command: ["/opt/janus/bin/janus", "-F", "/opt/janus/etc/janus", "--full-trickle"]
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./talk/janus.jcfg:/opt/janus/etc/janus/janus.jcfg:ro
      - ./talk/janus.transport.websockets.jcfg:/opt/janus/etc/janus/janus.transport.websockets.jcfg:ro
      # wsevh not needed - signaling server receives events via MCU connection
    # No ports exposed - signaling connects via internal Docker network (ws://janus:8188)
    # This prevents external access without api_secret authentication

  # ============================================================================
  # Komodo Periphery - Docker management agent
  # ============================================================================
  # Connects to Komodo Core over Tailnet for container orchestration
  # Port 8120 only listens on Tailscale interface (not exposed to internet)

  periphery:
    image: ghcr.io/moghtech/komodo-periphery:latest
    restart: unless-stopped
    labels:
      komodo.skip: "true"
    environment:
      PERIPHERY_PASSKEYS: ${PERIPHERY_PASSKEY}
      PERIPHERY_SSL_ENABLED: "false"
      PERIPHERY_INCLUDE_DISK_MOUNTS: /etc/hostname
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - /proc:/proc
      - /etc/komodo:/etc/komodo
    ports:
      # Bind to Tailscale IP only - set TAILSCALE_IP in .env
      - "${TAILSCALE_IP:-127.0.0.1}:8120:8120"

volumes:
  nextcloud_db:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: {{ mount_point }}/nextcloud_db
  nextcloud_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: {{ mount_point }}/nextcloud_data
  redis_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: {{ mount_point }}/redis_data
  backup_temp:
    driver: local
  clamav_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: {{ mount_point }}/clamav_data