drive.{{ domain }} {
    tls {
        dns hetzner {env.HETZNER_API_TOKEN}
        resolvers 8.8.8.8:53 1.1.1.1:53
    }

    header Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Client Push (notify_push) - real-time updates for desktop/mobile clients
    handle /push/* {
        reverse_proxy http://localhost:7867
    }

    # Default handler for all other requests
    handle {
        reverse_proxy http://localhost:8080
    }

    encode gzip zstd
}

office.{{ domain }} {
    tls {
        dns hetzner {env.HETZNER_API_TOKEN}
        resolvers 8.8.8.8:53 1.1.1.1:53
    }

    header Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Collabora Online requires these headers
    header X-Forwarded-Proto https
    header X-Forwarded-Host {host}

    reverse_proxy http://localhost:9980 {
        transport http {
            # Collabora needs long timeouts
            read_timeout 3600s
            write_timeout 3600s
        }
    }

    encode gzip zstd
}

healthcheck.{{ domain }} {
    respond "OK" 200
}

# Nextcloud Whiteboard WebSocket server
whiteboard.{{ domain }} {
    tls {
        dns hetzner {env.HETZNER_API_TOKEN}
        resolvers 8.8.8.8:53 1.1.1.1:53
    }

    header Strict-Transport-Security "max-age=31536000; includeSubDomains"

    reverse_proxy http://localhost:3002 {
        # Flush immediately for WebSocket connections
        flush_interval -1
        transport http {
            read_timeout 3600s
            write_timeout 3600s
        }
    }
}

# Nextcloud Talk High Performance Backend (signaling server)
signaling.{{ domain }} {
    tls {
        dns hetzner {env.HETZNER_API_TOKEN}
        resolvers 8.8.8.8:53 1.1.1.1:53
    }

    header Strict-Transport-Security "max-age=31536000; includeSubDomains"

    reverse_proxy http://localhost:8081 {
        # Flush immediately for WebSocket/SSE
        flush_interval -1
        transport http {
            # WebSocket connections need long timeouts
            read_timeout 3600s
            write_timeout 3600s
        }
    }
}