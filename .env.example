# Project root directory - used by PyInfra scripts to locate configuration files
# Auto-detected by looking for .git/, configs/, or pyproject.toml
export PROJECT_ROOT=${PWD}

# S3-compatible storage configuration for Terraform remote state
# Bucket name where Terraform state files are stored
export TF_S3_BUCKET=your-tfstate-bucket-name

# S3-compatible endpoint URL (e.g., https://fly.storage.tigris.dev for Tigris)
export TF_S3_ENDPOINT=https://your-s3-endpoint.example.com

# Region for S3-compatible storage (use 'auto' for providers like Tigris)
export TF_S3_REGION=auto

# Domain name for the reverse proxy and DNS records
# Example: example.com
export TF_VAR_domain=your-domain.com

# Hetzner Cloud API token (sensitive)
# Used for provisioning VPS instances, managing DNS zones, and Caddy DNS challenges
# Get this from: https://console.hetzner.cloud/ -> Security -> API Tokens
export TF_VAR_hcloud_token=your-hetzner-api-token

# SSH public key for deployment authentication on Hetzner VPS
# Used for initial VPS access during provisioning
# Example: ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQC...
export TF_VAR_ssh_key_deployment_public=your-ssh-public-key

# SSH private key for deployment authentication
# Used by GitHub Actions SSH agent for connecting to VPS during deployment
# Generate with: ssh-keygen -t rsa -b 4096 -C "deployment@your-domain.com"
export TF_VAR_ssh_key_deployment_private=your-ssh-private-key