# Project root directory - used by PyInfra scripts to locate configuration files
# Auto-detected by looking for .git/, configs/, or pyproject.toml
export PROJECT_ROOT=${PWD}

# S3-compatible storage configuration for Terraform remote state
# Bucket name where Terraform state files are stored
export TF_S3_BUCKET=your-tfstate-bucket-name

# S3-compatible endpoint URL (e.g., https://fly.storage.tigris.dev for Tigris)
export TF_S3_ENDPOINT=https://your-s3-endpoint.example.com

# Region for S3-compatible storage (use 'auto' for providers like Tigris)
export TF_S3_REGION=auto

# Project/client name used as prefix for all resources
# This helps avoid naming conflicts when reusing infrastructure code
export TF_VAR_project_name=myproject

# Domain name for the reverse proxy and DNS records
# Example: example.com
export TF_VAR_domain=your-domain.com

# Hetzner Cloud API token (sensitive)
# Used for provisioning VPS instances, managing DNS zones, and Caddy DNS challenges
# Get this from: https://console.hetzner.cloud/ -> Security -> API Tokens
export TF_VAR_hcloud_token=your-hetzner-api-token

# SSH public key for deployment authentication on Hetzner VPS
# Used for initial VPS access during provisioning
# Example: ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQC...
export TF_VAR_ssh_key_deployment_public=your-ssh-public-key

# SSH private key for deployment authentication
# Used by GitHub Actions SSH agent for connecting to VPS during deployment
# Generate with: ssh-keygen -t rsa -b 4096 -C "deployment@your-domain.com"
export TF_VAR_ssh_key_deployment_private=your-ssh-private-key

# Nextcloud database password (sensitive)
# Used by PostgreSQL and Nextcloud to authenticate database connections
# Generate with: openssl rand -base64 32
export POSTGRES_PASSWORD=your-postgres-password

# Nextcloud admin username
# Default admin account username for Nextcloud installation
# Optional: defaults to "admin" if not set
export NEXTCLOUD_ADMIN_USER=admin

# Nextcloud admin password (sensitive)
# Default admin account password for Nextcloud installation
# Generate with: openssl rand -base64 32
export NEXTCLOUD_ADMIN_PASSWORD=your-nextcloud-admin-password

# Redis password (sensitive)
# Used by Redis for authentication and Nextcloud for cache/locking
# Generate with: openssl rand -base64 32
export REDIS_PASSWORD=your-redis-password

# Restic repository password (sensitive)
# Used to encrypt Restic backups
# Generate with: openssl rand -base64 32
export RESTIC_PASSWORD=your-restic-password

# Hetzner region for Object Storage and resources
# Options: nbg1 (Nuremberg), fsn1 (Falkenstein), hel1 (Helsinki)
export TF_VAR_hetzner_region=nbg1

# Hetzner Object Storage credentials for backups
# Create these in Hetzner Cloud Console -> Object Storage -> Manage Keys
# Access key ID for S3-compatible storage
export TF_VAR_hetzner_s3_access_key=your-s3-access-key
# Secret access key for S3-compatible storage (sensitive)
export TF_VAR_hetzner_s3_secret_key=your-s3-secret-key

# Backup retention: keep daily backups for this many days
export BACKUP_RETENTION_DAYS=30