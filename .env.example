# ============================================================================
# Nextcloud Deployment Configuration
# ============================================================================
# Follow this file in order during deployment setup
# Generate secure passwords with: openssl rand -base64 32
# ============================================================================

# ----------------------------------------------------------------------------
# SECTION 1: PROJECT SETUP
# Fill this out first - basic project configuration
# ----------------------------------------------------------------------------

# Project root directory - used by PyInfra scripts to locate configuration files
# Auto-detected by looking for .git/, configs/, or pyproject.toml
export PROJECT_ROOT=${PWD}

# Project/client name used as prefix for all resources
# This helps avoid naming conflicts when reusing infrastructure code
# Example: myproject, acme-corp, etc.
export TF_VAR_project_name=myproject

# Domain name for the reverse proxy and DNS records
# This will be used for: drive.your-domain.com, office.your-domain.com
# Example: example.com
export TF_VAR_domain=your-domain.com

# ----------------------------------------------------------------------------
# SECTION 2: HETZNER CLOUD CREDENTIALS
# Get these from: https://console.hetzner.cloud/
# Required for: VPS provisioning, DNS management, Object Storage
# ----------------------------------------------------------------------------

# Hetzner Cloud API token (sensitive)
# Used for provisioning VPS instances, managing DNS zones, and Caddy DNS challenges
# Get from: Hetzner Console -> Security -> API Tokens
export TF_VAR_hcloud_token=your-hetzner-api-token

# Hetzner region for Object Storage and VPS location
# Options: nbg1 (Nuremberg), fsn1 (Falkenstein), hel1 (Helsinki)
# Recommended: Choose region closest to your users
export TF_VAR_hetzner_region=nbg1

# Hetzner server type for the Nextcloud VPS
# See: https://www.hetzner.com/cloud/#pricing
# Default: cpx42 (4 vCPU, 16 GB RAM)
export TF_VAR_instance_type=cpx42

# Size in GB for the attached data volume (stores Nextcloud data, DB, backups)
# Default: 50 GB - increase for larger user bases
export TF_VAR_volume_size_gb=50

# Hetzner Object Storage credentials for backups
# Create in: Hetzner Console -> Object Storage -> Manage Keys
# Access key ID for S3-compatible storage
export TF_VAR_hetzner_s3_access_key=your-s3-access-key

# Secret access key for S3-compatible storage (sensitive)
export TF_VAR_hetzner_s3_secret_key=your-s3-secret-key

# AWS-style credentials for Terraform S3 backend (use same values as above)
export AWS_ACCESS_KEY_ID=your-s3-access-key
export AWS_SECRET_ACCESS_KEY=your-s3-secret-key

# ----------------------------------------------------------------------------
# SECTION 3: TERRAFORM STATE STORAGE
# Required for: Storing Terraform state in S3
# Create bucket manually in Hetzner Console first
# ----------------------------------------------------------------------------

# S3 bucket name for Terraform state files
# Create this bucket manually: Hetzner Console -> Object Storage -> Create Bucket
# Example: myproject-terraform-state
export TF_S3_BUCKET=your-tfstate-bucket-name

# S3 endpoint URL for Terraform state (auto-constructed from region)
# Format: https://{region}.your-objectstorage.com
export TF_AWS_ENDPOINT_URL_S3=https://nbg1.your-objectstorage.com

# S3 region for Terraform state (should match TF_VAR_hetzner_region)
export TF_S3_REGION=nbg1

# ----------------------------------------------------------------------------
# SECTION 4: SSH KEYS FOR DEPLOYMENT
# Generate with: ssh-keygen -t ed25519 -C "deployment@your-domain.com"
# Required for: Initial VPS access and automated deployments
# ----------------------------------------------------------------------------

# SSH public key for deployment authentication on Hetzner VPS
# Used for initial VPS access during provisioning
# Get with: cat ~/.ssh/id_ed25519.pub
# Example: ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA...
export TF_VAR_ssh_key_deployment_public=your-ssh-public-key

# SSH private key for deployment authentication (optional)
# Only needed for CI/CD pipelines like GitHub Actions
# Get with: cat ~/.ssh/id_ed25519
export TF_VAR_ssh_key_deployment_private=your-ssh-private-key

# ----------------------------------------------------------------------------
# SECTION 5: APPLICATION PASSWORDS
# Generate ALL passwords with: openssl rand -base64 32
# IMPORTANT: Generate unique passwords for each service
# ----------------------------------------------------------------------------

# PostgreSQL database password (sensitive)
# Used by PostgreSQL and Nextcloud to authenticate database connections
# Generate with: openssl rand -base64 32
export POSTGRES_PASSWORD=your-postgres-password

# Redis cache password (sensitive)
# Used by Redis for authentication and Nextcloud for cache/locking
# Generate with: openssl rand -base64 32
export REDIS_PASSWORD=your-redis-password

# Nextcloud admin username
# Default admin account username for Nextcloud installation
# Recommended: Use something other than "admin" for security
export NEXTCLOUD_ADMIN_USER=admin

# Nextcloud admin password (sensitive)
# Default admin account password for Nextcloud installation
# Generate with: openssl rand -base64 32
export NEXTCLOUD_ADMIN_PASSWORD=your-nextcloud-admin-password

# Restic backup encryption password (sensitive)
# Used to encrypt Restic backups before upload to S3
# CRITICAL: Store this securely - cannot recover backups without it!
# Generate with: openssl rand -base64 32
export RESTIC_PASSWORD=your-restic-password

# ----------------------------------------------------------------------------
# SECTION 6: EMAIL CONFIGURATION (SMTP)
# Required for: User notifications, password resets, sharing
# Recommended provider: Brevo (free tier: 300 emails/day)
# Sign up at: https://www.brevo.com/
# ----------------------------------------------------------------------------

# SMTP server hostname
# Brevo default: smtp-relay.brevo.com
export SMTP_HOST=smtp-relay.brevo.com

# SMTP server port
# Standard TLS port: 587
export SMTP_PORT=587

# SMTP encryption method
# Options: tls, ssl, or none
export SMTP_SECURE=tls

# SMTP authentication type
# Standard: LOGIN
export SMTP_AUTHTYPE=LOGIN

# SMTP username (your Brevo account email)
# Note: Use SMTP_NAME not SMTP_USERNAME (Nextcloud Docker convention)
# Example: your-email@example.com
export SMTP_NAME=your-brevo-email@example.com

# SMTP password (API key from Brevo, NOT your account password!)
# Generate at: Brevo Dashboard -> SMTP & API -> SMTP -> Create a new SMTP key
# Example: xsmtpsib-abc123def456...
export SMTP_PASSWORD=your-brevo-smtp-key

# Email sender address (local part only, domain added automatically)
# Will become: noreply@your-domain.com
# Common values: noreply, no-reply, notifications
export MAIL_FROM_ADDRESS=noreply

# ----------------------------------------------------------------------------
# SECTION 7: EMAIL DNS VERIFICATION (OPTIONAL)
# Improves email deliverability and removes "sent via brevo.com" warnings
# Get from: Brevo Dashboard -> Settings -> Senders & IP -> Add Domain
# Leave empty to skip (emails will still work)
# ----------------------------------------------------------------------------

# Brevo domain verification code
# Shown as "code-verification" TXT record in Brevo
# Example: brevo-code:abc123def456...
export TF_VAR_brevo_verification_code=""

# SimpleLogin domain verification code
# Get from: SimpleLogin Dashboard -> Domains -> your domain -> DNS
# Example: sl-verification=abc123def456...
export TF_VAR_simplelogin_verification_code=""

# DKIM CNAME target 1
# Shown as mail._domainkey CNAME record in Brevo
# Format: b1.your-domain-com.dkim.brevo.com. (note the trailing dot!)
# Example: b1.example-com.dkim.brevo.com.
export TF_VAR_brevo_dkim_key1=""

# DKIM CNAME target 2
# Shown as mail2._domainkey CNAME record in Brevo
# Format: b2.your-domain-com.dkim.brevo.com. (note the trailing dot!)
# Example: b2.example-com.dkim.brevo.com.
export TF_VAR_brevo_dkim_key2=""

# ----------------------------------------------------------------------------
# SECTION 8: NEXTCLOUD TALK (VIDEO CONFERENCING)
# Required for: Video calls, screen sharing, team meetings
# Generate secrets with: openssl rand -hex 32
# ----------------------------------------------------------------------------

# TURN server shared secret (used by coturn and Nextcloud Talk)
# This authenticates TURN relay connections for NAT traversal
# Generate with: openssl rand -hex 32
export TURN_SECRET=your-turn-secret

# Signaling server (HPB) shared secret
# Used for backend authentication between Nextcloud and signaling server
# Generate with: openssl rand -hex 32
export SIGNALING_SECRET=your-signaling-secret

# Signaling server session hash key (minimum 16 bytes / 32 hex chars)
# Used for session encryption
# Generate with: openssl rand -hex 16
export SIGNALING_HASHKEY=your-signaling-hashkey

# Signaling server session block key (16 bytes for AES-128)
# Used for session encryption
# Generate with: openssl rand -hex 16
export SIGNALING_BLOCKKEY=your-signaling-blockkey

# Janus WebRTC gateway admin secret
# Randomized admin secret (admin API is disabled but good practice)
# Generate with: openssl rand -hex 32
export JANUS_ADMIN_SECRET=your-janus-admin-secret

# Janus TURN password
# Static password for Janus to authenticate with coturn TURN server
# Generate with: openssl rand -hex 32
export JANUS_TURN_PASSWORD=your-janus-turn-password

# Whiteboard JWT secret (shared between Nextcloud and whiteboard WebSocket server)
# Generate with: openssl rand -hex 32
export WHITEBOARD_JWT_SECRET=your-whiteboard-jwt-secret

# ----------------------------------------------------------------------------
# SECTION 9: BACKUP CONFIGURATION
# Optional but highly recommended for production
# ----------------------------------------------------------------------------

# S3 endpoint for Nextcloud backups (auto-constructed from region)
# These are automatically configured on the VPS by PyInfra from Terraform outputs
# Set these locally only if you need to run restic commands from your machine
# Get with: terraform output -raw s3_endpoint
export AWS_S3_ENDPOINT=https://nbg1.your-objectstorage.com

# S3 bucket name for Nextcloud backups (auto-generated by Terraform)
# Format: {project_name}-{random_id}-nextcloud-backups
# Get with: terraform output -raw s3_bucket
export AWS_S3_BUCKET=your-project-name-nextcloud-backups

# Daily backup retention period
# How many days of daily backups to keep before pruning
# Recommended: 30 (one month)
export BACKUP_RETENTION_DAYS=30

# Healthcheck monitoring URL (optional but recommended)
# Service like healthchecks.io that gets pinged after successful backups
# Sign up at: https://healthchecks.io (free tier available)
# Create check with: Period=1 day, Grace=2 hours
# Leave empty to disable healthcheck pings
# Example: https://hc-ping.com/c11bb854-0164-452b-acad-e0cd9e388c5c
export HEALTHCHECK_URL=

# ----------------------------------------------------------------------------
# SECTION 10: ADVANCED SETTINGS (OPTIONAL)
# These have sensible defaults - only change if needed
# ----------------------------------------------------------------------------

# Go version for building Caddy with DNS plugins
# Update periodically for security and performance improvements
# Check latest versions at: https://go.dev/dl/
# Default: 1.23.4
export GO_VERSION=1.26.1

# Nextcloud deployment directory on the VPS
# Default: /opt/nextcloud
# The Docker Compose project name (and therefore container names) is derived from
# the basename of this directory. If you change this, also set COMPOSE_PROJECT_NAME.
# export NEXTCLOUD_DIR=/opt/nextcloud

# Docker Compose project name (determines container name prefix)
# Default: basename of NEXTCLOUD_DIR (e.g. "nextcloud" for /opt/nextcloud)
# Must be set in the backup container environment and restore.sh to match.
# export COMPOSE_PROJECT_NAME=nextcloud

# Hetzner Object Storage domain suffix (advanced)
# Override only if Hetzner changes their S3-compatible storage domain.
# Default: your-objectstorage.com
# export HETZNER_S3_DOMAIN=your-objectstorage.com

# ----------------------------------------------------------------------------
# SECTION 11: TAILSCALE (REQUIRED FOR SSH ACCESS)
# SSH is blocked from public internet - Tailscale is required for deployment
# ----------------------------------------------------------------------------

# Tailscale auth key for cloud-init provisioning (REQUIRED)
# This key is used during VPS creation to join Tailscale before SSH is needed
# Generate at: Tailscale Admin Console -> Settings -> Keys -> Generate auth key
# IMPORTANT: Must be a reusable, non-ephemeral key with tag:vps-external
# The key needs these settings:
#   - Reusable: Yes (so Terraform can recreate VPS without new key)
#   - Ephemeral: No (VPS should persist in Tailnet)
#   - Tags: tag:vps-external
export TF_VAR_tailscale_auth_key=tskey-auth-...

# Tailscale auth key for PyInfra (same as above, different env var name)
export TAILSCALE_AUTH_KEY=tskey-auth-...

# VPS Tailnet hostname for SSH connections (OPTIONAL - auto-detected from Terraform)
# Override only if needed; PyInfra fetches this from `terraform output tailnet_hostname`
# Format: {project_name}-{suffix}-nextcloud
# export VPS_TAILNET_HOSTNAME=myproject-abc123-nextcloud

# ----------------------------------------------------------------------------
# SECTION 12: KOMODO (OPTIONAL)
# Required for: Integration with existing Komodo setup over Tailnet
# ----------------------------------------------------------------------------

# Passkey for Periphery agent authentication
# Must match PERIPHERY_PASSKEYS in your Komodo Core config
# Get from your existing Komodo deployment
export PERIPHERY_PASSKEY=

# ============================================================================
# DEPLOYMENT CHECKLIST
# ============================================================================
#
# Follow this order for a smooth deployment:
#
# □ 1. Fill out Section 1 (Project Setup)
# □ 2. Fill out Section 2 (Hetzner credentials)
# □ 3. Create S3 bucket manually in Hetzner Console (shared across all tenants)
# □ 4. Fill out Section 3 (Terraform state storage)
# □ 5. Copy terraform/backend.hcl.example -> terraform/backend.hcl
#       Set key = "tenants/{tenant-name}/terraform.tfstate"
# □ 6. Generate SSH key pair
# □ 7. Fill out Section 4 (SSH keys)
# □ 8. Generate all passwords with: openssl rand -base64 32
# □ 9. Fill out Section 5 (Application passwords)
# □ 10. Sign up for Brevo and get SMTP credentials
# □ 11. Fill out Section 6 (Email configuration)
# □ 12. (Optional) Add domain to Brevo and get verification codes
# □ 13. (Optional) Fill out Section 7 (Email DNS verification)
# □ 14. Generate Talk secrets with: openssl rand -hex 32
# □ 15. Fill out Section 8 (Nextcloud Talk)
# □ 16. (Optional) Sign up for Healthchecks.io and get ping URL
# □ 17. (Optional) Fill out Section 9 (Backup configuration)
# □ 18. Review Section 10 (Advanced settings)
# □ 19. Generate Tailscale OAuth client (see instructions below)
# □ 20. Fill out Section 11 (Tailscale - REQUIRED)
# □ 21. (Optional) Fill out Section 12 (Komodo)
# □ 22. Source this file: source .env
# □ 23. Run: terraform init -backend-config=terraform/backend.hcl
# □ 24. Run deployment: See README.md for deployment steps
#
# ============================================================================
